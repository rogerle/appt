# 🧘 Appt Yoga Studio Scheduler - Environment Variables Configuration
# ================================================================
# Copy this file to .env and fill in your values before deployment.
# DO NOT commit the actual .env file with sensitive data to version control!

# =============================================================================
# DATABASE CONFIGURATION (Required)
# =============================================================================

# PostgreSQL Connection String (Production/Development)
# Format: postgresql://username:password@host:port/database_name
# Example for Docker deployment: postgresql://appt_user:your_secure_password@db:5432/appt_production
DATABASE_URL=postgresql://appt_user:your_secure_password@db:5432/appt_production

# SQLite (Local Development Only - Not Recommended for Production)
# Format: sqlite:///./database_name.db
# DATABASE_URL=sqlite:///./dev.db  # Uncomment only for local testing

# =============================================================================
# SECURITY CONFIGURATION (Required - Generate Secure Values!)
# =============================================================================

# JWT Secret Key (CRITICAL - Must be unique and secure)
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# ⚠️ NEVER use a default or weak value in production!
SECRET_KEY=<generate-with-secrets-token-unsafe-long-string>

# JWT Algorithm (DO NOT CHANGE unless you have specific requirements)
ALGORITHM=HS256

# Access Token Expiration Time (in minutes)
# Recommended: 15-30 for web apps, longer for mobile offline sessions
ACCESS_TOKEN_EXPIRE_MINUTES=15

# =============================================================================
# APPLICATION CONFIGURATION (Required)
# =============================================================================

# Environment Mode (development/production/testing)
# IMPORTANT: Set to 'production' before deploying!
ENVIRONMENT=production

# Debug Flag (True = verbose errors, False = user-friendly messages)
# ⚠️ ALWAYS set DEBUG=False in production for security!
DEBUG=False

# =============================================================================
# CORS CONFIGURATION (Required - Critical Security Setting!)
# =============================================================================

# Allowed Origins List (JSON array of strings)
# Format: ["http://localhost:5173","https://your-domain.com"]
# ⚠️ NEVER use ["*"] with credentials=True (Critical security vulnerability!)
# ⚠️ Must match your frontend domain exactly, including protocol (http/https)

# Development (Local Testing):
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Production (Replace with YOUR actual domain):
# ALLOWED_ORIGINS=["https://your-domain.com","https://www.your-domain.com"]

# =============================================================================
# DATABASE CONNECTION POOL TUNING (Optional - Defaults are usually fine)
# =============================================================================

# Base Pool Size (Number of persistent connections)
# Recommended: 10 for low-traffic sites, 20+ for high-traffic production
DATABASE_POOL_SIZE=10

# Maximum Overflow Connections (Additional connections during burst traffic)
# Recommended: 2x pool_size for most applications
DATABASE_MAX_OVERFLOW=20

# Connection Recycle Time (Seconds before reusing connection - prevents stale connections)
# Recommended: 3600 (1 hour) to balance performance and stability
DATABASE_POOL_RECYCLE=3600

# Connection Timeout (Seconds waiting for available connection from pool)
# Recommended: 30 (increase if you see timeout errors under load)
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# PERFORMANCE TUNING (Optional - Advanced Users Only)
# =============================================================================

# Uvicorn Worker Count (Number of parallel processes)
# Recommended: CPU cores * 2 + 1, or use auto for automatic detection
UVICORN_WORKERS=4

# Request Size Limit (Bytes) - Prevents excessive payload attacks
# Default: 10MB (10485760 bytes), increase only if needed for file uploads
MAX_REQUEST_SIZE_BYTES=10485760

# Rate Limiting (Requests per minute per IP address)
# Recommended: 60 for public endpoints, higher for internal APIs
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# LOGGING CONFIGURATION (Optional - Defaults to INFO level)
# =============================================================================

# Log Level (DEBUG < INFO < WARNING < ERROR < CRITICAL)
# Production: INFO or WARNING; Development: DEBUG
LOG_LEVEL=INFO

# Enable Detailed Query Logging (True = logs all SQL queries, False = only errors)
# ⚠️ Set to False in production for performance and security!
ENABLE_QUERY_LOGGING=False

# =============================================================================
# BACKUP CONFIGURATION (Optional - For Production Deployments)
# =============================================================================

# Database Backup Directory (Absolute path on host system)
BACKUP_DIR=/backups/appt

# Backup Retention Days (How many days to keep old backups before deletion)
BACKUP_RETENTION_DAYS=30

# Automatic Backup Schedule (Cron expression: minute hour day month weekday)
# Example: "0 2 * * *" = Daily at 2 AM
AUTO_BACKUP_SCHEDULE="0 2 * * *"

# =============================================================================
# MONITORING & ALERTING (Optional - For Production Deployments)
# =============================================================================

# Enable Prometheus Metrics Endpoint (True to expose /metrics endpoint)
PROMETHEUS_METRICS_ENABLED=False

# Sentry DSN (Error tracking service - Get from sentry.io if using)
SENTRY_DSN=

# Health Check Interval (Seconds between automated health checks)
HEALTH_CHECK_INTERVAL=60

# =============================================================================
# FRONTEND CONFIGURATION (Optional - For PWA Features)
# =============================================================================

# Frontend API Base URL (If frontend is served separately from backend)
API_BASE_URL=http://localhost:8000/api/v1

# PWA App Name (Displayed on home screen when added to device)
PWA_APP_NAME=Appt Yoga Studio

# PWA Theme Color (Primary color for mobile UI)
PWA_THEME_COLOR=#0071e3

# =============================================================================
# DEVELOPMENT MODE OVERRIDES (Optional - Only use during local development!)
# =============================================================================

# Disable all security checks for testing (NEVER USE IN PRODUCTION!)
DISABLE_SECURITY_CHECKS=False

# Use in-memory database instead of PostgreSQL (Very fast for tests, data lost on restart)
USE_IN_MEMORY_DATABASE=False

# Enable demo mode with pre-populated test data
ENABLE_DEMO_MODE=False

# =============================================================================
# EXAMPLE CONFIGURATIONS FOR DIFFERENT ENVIRONMENTS
# =============================================================================

### Development Environment (.env.dev)
# DATABASE_URL=sqlite:///./dev.db
# SECRET_KEY=<use-short-key-for-local-development>
# DEBUG=True
# ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
# ENVIRONMENT=development

### Production Environment (.env) - REQUIRED FOR PRODUCTION DEPLOYMENT!
# DATABASE_URL=postgresql://appt_user:your_secure_password@db:5432/appt_production
# SECRET_KEY=<generate-with-secrets-token-unsafe-long-string>
# DEBUG=False
# ALLOWED_ORIGINS=["https://your-domain.com","https://www.your-domain.com"]
# ENVIRONMENT=production

### Testing Environment (.env.test)
# DATABASE_URL=sqlite:///./test.db
# SECRET_KEY=test-secret-key-for-automation-only-not-secure
# DEBUG=True
# ALLOWED_ORIGINS=["*"]  # Allow all for testing (not recommended in production!)
# ENVIRONMENT=testing

# =============================================================================
# SECURITY BEST PRACTICES - READ BEFORE DEPLOYMENT!
# =============================================================================

# 🔴 CRITICAL: Always generate a unique SECRET_KEY using Python secrets module:
# python3 -c 'import secrets; print(secrets.token_urlsafe(32))'

# 🟡 WARNING: Never use ["*"] for ALLOWED_ORIGINS when credentials are enabled!
# This creates a critical CORS vulnerability that exposes your API to any website.

# 🟢 RECOMMENDED: Set DEBUG=False in production to prevent error message leakage.

# 🔵 IMPORTANT: Always verify SSL certificates are valid before going live.
# Use Let's Encrypt (free) or commercial certificate provider for HTTPS.

# =============================================================================
# DEPLOYMENT CHECKLIST - VERIFY BEFORE GOING LIVE!
# =============================================================================

# ✅ Change all default passwords (database, admin accounts)
# ✅ Generate secure SECRET_KEY (not hardcoded in code!)
# ✅ Disable DEBUG mode (DEBUG=False)
# ✅ Configure CORS with specific origins (never use ["*"] with credentials)
# ✅ Enable HTTPS with valid SSL certificate
# ✅ Set up firewall rules (UFW or cloud provider security groups)
# ✅ Configure database user permissions (least privilege principle)

# =============================================================================
# TROUBLESHOOTING & FAQ
# =============================================================================

# Q: What if I get "Could not obtain a connection from the pool"?
# A: Increase DATABASE_POOL_SIZE and DATABASE_MAX_OVERFLOW values.

# Q: How do I change the database host for Docker deployment?
# A: Use service name 'db' in Docker Compose, or IP address for external DB.

# Q: Can I use SQLite in production?
# A: Not recommended - PostgreSQL provides better performance and concurrency.

# Q: What happens if SECRET_KEY is changed after users have logged in?
# A: All existing JWT tokens become invalid - users must re-login.

# Q: How often should I rotate the SECRET_KEY?
# A: Every 90 days is recommended for high-security environments, but requires token refresh strategy.

