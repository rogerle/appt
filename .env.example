# Appt Project - Environment Configuration Template
# Copy this file to .env and fill in your values
# WARNING: Never commit .env to version control!

---

## Database Configuration (PostgreSQL)
POSTGRES_DB=appt                 # Database name
POSTGRES_USER=appt_user          # Database username
POSTGRES_PASSWORD=change_me_in_production  # ⚠️ CHANGE THIS! Use strong password in production

# Connection URL (auto-generated from above variables, but can be customized)
DATABASE_URL=postgresql://appt_user:your_password@postgres:5432/appt

---

## Application Security
SECRET_KEY=change_this_to_a_random_512bit_key_in_production  # JWT signing key
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"

# Admin credentials (first-time setup only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production  # ⚠️ CHANGE THIS!

---

## Environment Mode
FASTAPI_ENV=production  # Options: development, production, test

---

## CORS Configuration (Optional - for multi-domain deployments)
# Allow specific origins instead of * for security
CORS_ORIGINS=["http://localhost:8080","https://your-domain.com"]

---

## JWT Token Settings
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours default expiration

---

## Optional: Performance Tuning
# Database connection pool settings (for production)
DATABASE_POOL_SIZE=10            # Base pool size
DATABASE_MAX_OVERFLOW=20         # Max overflow connections
DATABASE_POOL_TIMEOUT=30         # Connection acquisition timeout (seconds)
DATABASE_POOL_RECIRCLE=3600      # Recycle connections every hour

---

## Optional: Logging Level
LOG_LEVEL=INFO                   # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

---

# Pre-deployment Checklist ✅
# Before deploying to production:
# [ ] Change all default passwords (POSTGRES_PASSWORD, ADMIN_PASSWORD)
# [ ] Generate a strong SECRET_KEY using the command above
# [ ] Update CORS_ORIGINS with your actual domain(s)
# [ ] Remove this .env.example file or rename it after creating real .env
